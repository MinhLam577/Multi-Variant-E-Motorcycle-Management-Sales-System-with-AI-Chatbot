{
    "compilerOptions": {
        // === BẮT BUỘC CHO VITE ===
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "types": ["vite/client"],
        "experimentalDecorators": true,
        "useDefineForClassFields": false,
        "emitDecoratorMetadata": true,
        // === Giữ lại những cái bạn cần ===
        "strict": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "baseUrl": "./",
        "paths": {
            "@/*": ["src/*"]
        }, // nếu bạn dùng alias @/...
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": false,
        "noFallthroughCasesInSwitch": false,
        "allowJs": true,
        "checkJs": true,

        // === Tùy chọn bạn có thể tắt bớt để nhẹ hơn (không bắt buộc) ===
        "strictNullChecks": false,
        "noImplicitAny": false,
        "strictBindCallApply": false,

        // === Các option khác (giữ nguyên hoặc thêm) ===
        "isolatedModules": true, // bắt buộc với Vite/esbuild
        "noEmit": true, // Vite sẽ build, tsc chỉ dùng để check type
        "lib": ["DOM", "DOM.Iterable", "ES2022"]
    },
    "include": [
        "src/**/*.d.ts",
        "src/**/*",
        "test/**/*",
        "typings/**/*",
        ".vite" // nếu có file custom d.ts của Vite
    ],
    "exclude": ["node_modules", "dist"]
}
